# SPECTRA — Environment Variables
# Copy this to spectra-app/.env.local and fill in real values — never commit .env.local to git

# ── Database ──────────────────────────────────────────────────────────────────
DB_SERVER=localhost
DB_NAME=SPECTRA
# Leave DB_USER blank to use Windows Authentication (recommended for local dev)
DB_USER=
DB_PASSWORD=
# DB_ODBC_DRIVER=ODBC Driver 18 for SQL Server

# ── OpenAI (AI Insights + Risk Summary features) ──────────────────────────────
OPENAI_API_KEY=sk-...

# ── Auth / RBAC ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production
CLIENT_PORTAL_PASSWORD=spectra2025
